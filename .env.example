# Copia a .env.local en la raíz del proyecto (opcional)

# API (OBLIGATORIO en Netlify — URL de tu backend desplegado)
# Ejemplo Render: https://puente-zardain-api.onrender.com/api
VITE_API_URL=https://TU-API.onrender.com/api

# Opcional si el socket no está en el mismo host que /api
# VITE_SOCKET_URL=https://TU-API.onrender.com

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

VITE_GOOGLE_MAPS_API_KEY=tu_api_key_google_maps
